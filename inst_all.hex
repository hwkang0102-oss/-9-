// 1. IP 초기화 및 오차값 0 설정 (Epsilon=0, Key=A, Clear=1)
07C0A800  // ADDI R31, R0, 0xA800 
07C0A000  // ADDI R31, R0, 0xA000 (Clear OFF)

// 2. 가상의 광선 데이터 세팅 (R1 = 0x1234)
00401234  // ADDI R1, R0, 0x1234

// 3. 메모리에 광선 데이터 쓰기 (주소 0번지에 0x1234 저장)
A8400000  // ST R1, R0, 0

// 4. 가속기에 데이터 8번 우겨넣기 (파싱)
// --- 패킷 1 ---
98800000  // LD R2, R0, 0         (데이터를 메모리에서 꺼내면 IPIN으로 흘러감)
07C0A400  // ADDI R31, R0, 0xA400 (Sample Toggle ON)
07C0A000  // ADDI R31, R0, 0xA000 (Sample Toggle OFF)
// --- 패킷 2 ---
98800000  // LD R2, R0, 0
07C0A400  // ADDI R31, R0, 0xA400
07C0A000  // ADDI R31, R0, 0xA000
// --- 패킷 3 ---
98800000  // LD R2, R0, 0
07C0A400  // ADDI R31, R0, 0xA400
07C0A000  // ADDI R31, R0, 0xA000
// --- 패킷 4 ---
98800000  // LD R2, R0, 0
07C0A400  // ADDI R31, R0, 0xA400
07C0A000  // ADDI R31, R0, 0xA000
// --- 패킷 5 ---
98800000  // LD R2, R0, 0
07C0A400  // ADDI R31, R0, 0xA400
07C0A000  // ADDI R31, R0, 0xA000
// --- 패킷 6 ---
98800000  // LD R2, R0, 0
07C0A400  // ADDI R31, R0, 0xA400
07C0A000  // ADDI R31, R0, 0xA000
// --- 패킷 7 ---
98800000  // LD R2, R0, 0
07C0A400  // ADDI R31, R0, 0xA400
07C0A000  // ADDI R31, R0, 0xA000
// --- 패킷 8 ---
98800000  // LD R2, R0, 0
07C0A400  // ADDI R31, R0, 0xA400
07C0A000  // ADDI R31, R0, 0xA000

// 5. 연산 마무리 명령 (Finish Toggle)
07C0A200  // ADDI R31, R0, 0xA200 (Finish Toggle ON)
07C0A000  // ADDI R31, R0, 0xA000 (Finish Toggle OFF)

// 6. 가속기 연산 시간 벌어주기 (NOP 5번)
00000000
00000000
00000000
00000000
00000000
