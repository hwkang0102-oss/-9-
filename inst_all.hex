// =========================================================================
// [1] 컨트롤 레지스터 세팅 (Epsilon = 10 으로 설정)
// Epsilon(10)을 상위 16비트로 밀어넣고, 각종 제어 스위치 조합을 미리 만듭니다.
// =========================================================================
01400010 // 00: ADDI R5, R0, 16      (시프트 연산용 16)
0500000A // 04: ADDI R20, R0, 10     (Epsilon = 10)
6D285000 // 08: SHL R20, R20, R5     (R20 = 0x000A 0000)
0568A800 // 0C: ADDI R21, R20, 0xA800 (R21 = Clear ON)
05A8A000 // 10: ADDI R22, R20, 0xA000 (R22 = 스위치 대기 상태)
05E8A400 // 14: ADDI R23, R20, 0xA400 (R23 = Sample 토글 ON)
0628A200 // 18: ADDI R24, R20, 0xA200 (R24 = Finish 토글 ON)

// =========================================================================
// [2] 3D 광선 데이터(방향 벡터) 메모리 세팅
// =========================================================================
02800000 // 1C: ADDI R10, R0, 0      (빈 데이터)
02C00064 // 20: ADDI R11, R0, 100    (Ray 1의 Y방향 = 100)
03000069 // 24: ADDI R12, R0, 105    (Ray 2의 Y방향 = 105) 
034000C8 // 28: ADDI R13, R0, 200    (Ray 3의 Y방향 = 200)

AA800000 // 2C: ST R10, R0, 0   (메모리 0번지: 0 저장)
AAC00004 // 30: ST R11, R0, 4   (메모리 4번지: 100 저장)
AB000008 // 34: ST R12, R0, 8   (메모리 8번지: 105 저장)
AB40000C // 38: ST R13, R0, 12  (메모리 12번지: 200 저장)

// =========================================================================
// [3] Ray 1 전송: 캐시가 비어있으므로 무조건 연산 (Cache Miss)
// =========================================================================
07EA0000 // 3C: ADDI R31, R21, 0 (가속기 Clear 초기화)
07EC0000 // 40: ADDI R31, R22, 0 
98400000 // 44: LD R1, R0, 0     (Packet 0, 1, 2 = 0)
07EE0000 // 48: ADDI R31, R23, 0 (Sample ON)
07EC0000 // 4C: ADDI R31, R22, 0 (Sample OFF)
98400000 // 50: LD R1, R0, 0
07EE0000 // 54: ADDI R31, R23, 0
07EC0000 // 58: ADDI R31, R22, 0
98400000 // 5C: LD R1, R0, 0
07EE0000 // 60: ADDI R31, R23, 0
07EC0000 // 64: ADDI R31, R22, 0
// ---> 패킷 3번에 Dir_Y (100) 주입
98400004 // 68: LD R1, R0, 4     
07EE0000 // 6C: ADDI R31, R23, 0
07EC0000 // 70: ADDI R31, R22, 0
// ---> 패킷 4~7 빈 데이터 주입 (길이 관계상 반복 축약 패턴 사용)
98400000 // 74: LD R1, R0, 0
07EE0000 // 78: ADDI R31, R23, 0
07EC0000 // 7C: ADDI R31, R22, 0
98400000 // 80: LD R1, R0, 0
07EE0000 // 84: ADDI R31, R23, 0
07EC0000 // 88: ADDI R31, R22, 0
98400000 // 8C: LD R1, R0, 0
07EE0000 // 90: ADDI R31, R23, 0
07EC0000 // 94: ADDI R31, R22, 0
98400000 // 98: LD R1, R0, 0
07EE0000 // 9C: ADDI R31, R23, 0
07EC0000 // A0: ADDI R31, R22, 0
// ---> 연산 마무리 및 대기
07F00000 // A4: ADDI R31, R24, 0 (Finish ON)
07EC0000 // A8: ADDI R31, R22, 0 (Finish OFF)
00000000 // AC: NOP

// =========================================================================
// [4] Ray 2 전송: 이전 광선(100)과 현재(105) 차이가 Epsilon(10) 이내! (Cache Hit 🌟)
// =========================================================================
98400000 // B0: LD R1, R0, 0
07EE0000 // B4: ADDI R31, R23, 0
07EC0000 // B8: ADDI R31, R22, 0
98400000 // BC: LD R1, R0, 0
07EE0000 // C0: ADDI R31, R23, 0
07EC0000 // C4: ADDI R31, R22, 0
98400000 // C8: LD R1, R0, 0
07EE0000 // CC: ADDI R31, R23, 0
07EC0000 // D0: ADDI R31, R22, 0
// ---> 패킷 3번에 Dir_Y (105) 주입
98400008 // D4: LD R1, R0, 8     
07EE0000 // D8: ADDI R31, R23, 0
07EC0000 // DC: ADDI R31, R22, 0
98400000 // E0: LD R1, R0, 0
07EE0000 // E4: ADDI R31, R23, 0
07EC0000 // E8: ADDI R31, R22, 0
98400000 // EC: LD R1, R0, 0
07EE0000 // F0: ADDI R31, R23, 0
07EC0000 // F4: ADDI R31, R22, 0
98400000 // F8: LD R1, R0, 0
07EE0000 // FC: ADDI R31, R23, 0
07EC0000 // 100: ADDI R31, R22, 0
98400000 // 104: LD R1, R0, 0
07EE0000 // 108: ADDI R31, R23, 0
07EC0000 // 10C: ADDI R31, R22, 0
07F00000 // 110: ADDI R31, R24, 0 (Finish ON)
07EC0000 // 114: ADDI R31, R22, 0 (Finish OFF)
00000000 // 118: NOP

// =========================================================================
// [5] Ray 3 전송: 이전 광선(100)과 현재(200) 차이가 100! (Cache Miss 🔥)
// =========================================================================
98400000 // 11C: LD R1, R0, 0
07EE0000 // 120: ADDI R31, R23, 0
07EC0000 // 124: ADDI R31, R22, 0
98400000 // 128: LD R1, R0, 0
07EE0000 // 12C: ADDI R31, R23, 0
07EC0000 // 130: ADDI R31, R22, 0
98400000 // 134: LD R1, R0, 0
07EE0000 // 138: ADDI R31, R23, 0
07EC0000 // 13C: ADDI R31, R22, 0
// ---> 패킷 3번에 Dir_Y (200) 주입
9840000C // 140: LD R1, R0, 12   
07EE0000 // 144: ADDI R31, R23, 0
07EC0000 // 148: ADDI R31, R22, 0
98400000 // 14C: LD R1, R0, 0
07EE0000 // 150: ADDI R31, R23, 0
07EC0000 // 154: ADDI R31, R22, 0
98400000 // 158: LD R1, R0, 0
07EE0000 // 15C: ADDI R31, R23, 0
07EC0000 // 160: ADDI R31, R22, 0
98400000 // 164: LD R1, R0, 0
07EE0000 // 168: ADDI R31, R23, 0
07EC0000 // 16C: ADDI R31, R22, 0
98400000 // 170: LD R1, R0, 0
07EE0000 // 174: ADDI R31, R23, 0
07EC0000 // 178: ADDI R31, R22, 0
07F00000 // 17C: ADDI R31, R24, 0 (Finish ON)
07EC0000 // 180: ADDI R31, R22, 0 (Finish OFF)

00000000 // 무한 NOP 루프...
