// =============================================================================
//  inst.hex  -  TC-RTBIA Custom IP 구동 프로그램 (수정본)
//
//  [핵심 수정]
//   1) 데이터 주입을 LD(opcode19, DRW=2'b10, DOUT1->CPU) 가 아니라
//      LDIP(opcode23, DRW=2'b11, DOUT2->IPIN) 로 변경  → IPIN 이 비로소 구동됨
//   2) "패킷당 sample_toggle 1회(엣지 1개)" 규칙 준수 (MAC 예제와 동일 cadence)
//   3) 광선 3개로 Temporal-Coherence Cache 시연
//        Ray1(dir_y=100) : 캐시 비어있음 -> MISS (엔진 연산)
//        Ray2(dir_y=105) : |105-100|=5 <= epsilon(10) -> HIT (캐시 우회)
//        Ray3(dir_y=200) : |200-100|=100 > epsilon(10) -> MISS (재연산)
//   4) 결과/상태를 STIP 로 DATA_MEM 에 저장 (과제 필수 요구사항)
//
//  CON 워드 배치 : CON[31:16]=epsilon=10, CON[15:12]=key(A)
//    R21=0x000AA800 clear(clear=1)         R22=0x000AA000 idle/sample0/sel0
//    R23=0x000AA400 sample_toggle=1        R24=0x000AA200 finish=1 / sel=0
//    R25=0x000AA300 finish=1 / sel=1(status)
//
//  DEMUX(Custom_IP.v): packet3 의 IPIN[15:0] 가 ray_dir_y 로 들어감
//    -> packet3 에서만 dir_y 값을 LDIP, 나머지 packet 은 0
// =============================================================================

// ---- [SETUP] epsilon 및 제어 워드 생성 -------------------------------------
01400010 // 00: ADDI R5 , R0 , 16          ; shift amount 16
0500000A // 04: ADDI R20, R0 , 10          ; epsilon = 10
6D285000 // 08: SHL  R20, R20, R5          ; R20 = 0x000A0000  (epsilon<<16)
0568A800 // 0C: ADDI R21, R20, 0xA800      ; R21 = 0x000AA800  clear_config
05A8A000 // 10: ADDI R22, R20, 0xA000      ; R22 = 0x000AA000  idle / sel=0
05E8A400 // 14: ADDI R23, R20, 0xA400      ; R23 = 0x000AA400  sample_toggle=1
0628A200 // 18: ADDI R24, R20, 0xA200      ; R24 = 0x000AA200  finish=1 , sel=0
0668A300 // 1C: ADDI R25, R20, 0xA300      ; R25 = 0x000AA300  finish=1 , sel=1(status)

// ---- [SETUP] dir_y 데이터를 DATA_MEM 에 적재 -------------------------------
02800000 // 20: ADDI R10, R0 , 0           ; value 0
02C00064 // 24: ADDI R11, R0 , 100         ; Ray1 dir_y = 100
03000069 // 28: ADDI R12, R0 , 105         ; Ray2 dir_y = 105
034000C8 // 2C: ADDI R13, R0 , 200         ; Ray3 dir_y = 200
AA800000 // 30: ST   R10, M[0]             ; mem[0]  = 0
AAC00004 // 34: ST   R11, M[4]             ; mem[4]  = 100
AB000008 // 38: ST   R12, M[8]             ; mem[8]  = 105
AB40000C // 3C: ST   R13, M[12]            ; mem[12] = 200

// ---- [CLEAR] 프로토콜 상태 초기화 ------------------------------------------
07EA0000 // 40: ADDI R31, R21, 0           ; clear_config (cfg_byte=0x00)
07EC0000 // 44: ADDI R31, R22, 0           ; release clear (모든 토글 0)

// =============================================================================
//  RAY 1  (dir_y=100)  : 캐시 비어있음 -> MISS, 엔진이 직접 연산
//  cadence = LDIP -> toggle , 패킷당 엣지 1개 (R23<->R22 교대)
// =============================================================================
B83E0000 // 48: LDIP M[0]                  ; packet0 = 0
07EE0000 // 4C: ADDI R31, R23, 0           ;   sample edge (0->1)
B83E0000 // 50: LDIP M[0]                  ; packet1 = 0
07EC0000 // 54: ADDI R31, R22, 0           ;   sample edge (1->0)
B83E0000 // 58: LDIP M[0]                  ; packet2 = 0
07EE0000 // 5C: ADDI R31, R23, 0           ;   edge
B83E0004 // 60: LDIP M[4]                  ; packet3 = 100  (ray_dir_y)
07EC0000 // 64: ADDI R31, R22, 0           ;   edge
B83E0000 // 68: LDIP M[0]                  ; packet4 = 0
07EE0000 // 6C: ADDI R31, R23, 0           ;   edge
B83E0000 // 70: LDIP M[0]                  ; packet5 = 0
07EC0000 // 74: ADDI R31, R22, 0           ;   edge
B83E0000 // 78: LDIP M[0]                  ; packet6 = 0
07EE0000 // 7C: ADDI R31, R23, 0           ;   edge
B83E0000 // 80: LDIP M[0]                  ; packet7 = 0  -> parsing_done(Ray1)
07EC0000 // 84: ADDI R31, R22, 0           ;   edge (8th sample)

// ---- Ray1 결과 안정화 대기 후 저장 -----------------------------------------
00000000 // 88: NOP   (pipeline drain)
00000000 // 8C: NOP
00000000 // 90: NOP
00000000 // 94: NOP
00000000 // 98: NOP
00000000 // 9C: NOP
00000000 // A0: NOP
00000000 // A4: NOP
C03E0040 // A8: STIP M[0x40]               ; DATA_MEM[0x40] = Ray1 result (sel=0)

// =============================================================================
//  RAY 2  (dir_y=105)  : |105-100|=5 <= epsilon(10) -> HIT, 캐시값 사용
// =============================================================================
B83E0000 // AC: LDIP M[0]                  ; packet0
07EE0000 // B0: ADDI R31, R23, 0
B83E0000 // B4: LDIP M[0]                  ; packet1
07EC0000 // B8: ADDI R31, R22, 0
B83E0000 // BC: LDIP M[0]                  ; packet2
07EE0000 // C0: ADDI R31, R23, 0
B83E0008 // C4: LDIP M[8]                  ; packet3 = 105  (ray_dir_y)
07EC0000 // C8: ADDI R31, R22, 0
B83E0000 // CC: LDIP M[0]                  ; packet4
07EE0000 // D0: ADDI R31, R23, 0
B83E0000 // D4: LDIP M[0]                  ; packet5
07EC0000 // D8: ADDI R31, R22, 0
B83E0000 // DC: LDIP M[0]                  ; packet6
07EE0000 // E0: ADDI R31, R23, 0
B83E0000 // E4: LDIP M[0]                  ; packet7 -> parsing_done(Ray2) HIT
07EC0000 // E8: ADDI R31, R22, 0

00000000 // EC: NOP
00000000 // F0: NOP
00000000 // F4: NOP
00000000 // F8: NOP
00000000 // FC: NOP
00000000 // 100: NOP
00000000 // 104: NOP
00000000 // 108: NOP
C03E0044 // 10C: STIP M[0x44]              ; DATA_MEM[0x44] = Ray2 result (캐시HIT => Ray1과 동일해야 정상)

// =============================================================================
//  RAY 3  (dir_y=200)  : |200-100|=100 > epsilon(10) -> MISS, 엔진 재연산
// =============================================================================
B83E0000 // 110: LDIP M[0]                 ; packet0
07EE0000 // 114: ADDI R31, R23, 0
B83E0000 // 118: LDIP M[0]                 ; packet1
07EC0000 // 11C: ADDI R31, R22, 0
B83E0000 // 120: LDIP M[0]                 ; packet2
07EE0000 // 124: ADDI R31, R23, 0
B83E000C // 128: LDIP M[12]                ; packet3 = 200  (ray_dir_y)
07EC0000 // 12C: ADDI R31, R22, 0
B83E0000 // 130: LDIP M[0]                 ; packet4
07EE0000 // 134: ADDI R31, R23, 0
B83E0000 // 138: LDIP M[0]                 ; packet5
07EC0000 // 13C: ADDI R31, R22, 0
B83E0000 // 140: LDIP M[0]                 ; packet6
07EE0000 // 144: ADDI R31, R23, 0
B83E0000 // 148: LDIP M[0]                 ; packet7 -> parsing_done(Ray3) MISS
07EC0000 // 14C: ADDI R31, R22, 0

00000000 // 150: NOP
00000000 // 154: NOP
00000000 // 158: NOP
00000000 // 15C: NOP
00000000 // 160: NOP
00000000 // 164: NOP
00000000 // 168: NOP
00000000 // 16C: NOP
C03E0048 // 170: STIP M[0x48]              ; DATA_MEM[0x48] = Ray3 result (재연산값)

// =============================================================================
//  FINISH + STATUS  (done=1 만든 뒤 결과/상태워드 저장)
// =============================================================================
07F00000 // 174: ADDI R31, R24, 0          ; finish_toggle (finish=1, sel=0)  [finish edge]
00000000 // 178: NOP   (done 확정 + drain)
00000000 // 17C: NOP
00000000 // 180: NOP
00000000 // 184: NOP
00000000 // 188: NOP
00000000 // 18C: NOP
C03E0080 // 190: STIP M[0x80]              ; DATA_MEM[0x80] = workload result (sel=0)
07F20000 // 194: ADDI R31, R25, 0          ; output_select=1 (status word 선택, finish 유지)
00000000 // 198: NOP   (IPOUT 가 status 로 갱신될 시간)
00000000 // 19C: NOP
00000000 // 1A0: NOP
00000000 // 1A4: NOP
C03E0084 // 1A8: STIP M[0x84]              ; DATA_MEM[0x84] = status word (0x269800xx 형태)

00000000 // 1AC: NOP (idle)
00000000 // 1B0: NOP
00000000 // 1B4: NOP
